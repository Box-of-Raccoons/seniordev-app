{
  "name": "seniordev-app",
  "version": "0.1.0",
  "description": "SeniorDev — Jira ticket workbench + tabbed interactive CLI multiplexer",
  "license": "MIT",
  "author": "Box of Raccoons <hardy.spry@boxofraccoons.dev>",
  "homepage": "https://github.com/Box-of-Raccoons/seniordev-app#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Box-of-Raccoons/seniordev-app.git"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "watch": "electron-vite build && electron out/main/watch.js",
    "watch:build": "electron-vite build",
    "rebuild": "electron-rebuild -f",
    "dist": "electron-vite build && electron-rebuild -f && electron-builder",
    "dist:dir": "electron-vite build && electron-rebuild -f && electron-builder --dir"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^26.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
